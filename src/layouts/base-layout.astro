---
import Header from '../components/header.astro'
import Footer from '../components/footer.astro'
import WhatsappFab from '../components/whatsapp-fab.astro'
import '../styles/global.css'

import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '@fontsource/outfit/900.css';

interface Props {
	title: string
	description?: string
}

const { title, description = "Grupo CTB - Construtora e Terraplenagem Brasil. Construindo o futuro sustentável." } = Astro.props
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		
		<title>{title}</title>
		<slot name="head" />
	</head>
	<body
		class="bg-brand-light text-brand-primary font-sans antialiased selection:bg-brand-accent selection:text-brand-secondary overflow-x-hidden"
	>
		<Header />
		<div class="flex flex-col min-h-screen overflow-x-hidden w-full relative">
			<main class="grow">
				<slot />
			</main>
			<Footer />
		</div>
		<WhatsappFab />
	</body>
</html>
