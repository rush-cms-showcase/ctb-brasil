---
import IconArrowRight from '~icons/ph/arrow-right-bold'

interface Props {
	title: string
	description?: string
	cta?: { label?: string; href: string }
}

const { title, description, cta } = Astro.props
---

<div class="mb-16 flex flex-col md:flex-row md:justify-between md:items-end gap-6">
	<div>
		<h2 class="text-4xl md:text-5xl font-display font-bold text-brand-primary">{title}</h2>
		{description && (
			<p class="mt-4 text-xl text-brand-primary/60 max-w-2xl text-balance">{description}</p>
		)}
	</div>
	{cta && (
		<a href={cta.href} class="inline-flex items-center gap-2 font-bold text-brand-primary hover:text-brand-accent transition">
			{cta.label ?? 'Ver todos'} <IconArrowRight />
		</a>
	)}
</div>
