---
import IconEnvelope from '~icons/ph/envelope-simple-light'
import IconPhone from '~icons/ph/phone-light'
import IconInstagram from '~icons/ph/instagram-logo-light'
import IconLinkedin from '~icons/ph/linkedin-logo-light'
import IconFacebook from '~icons/ph/facebook-logo-light'
import { whatsappUrl } from '../utils/whatsapp'
import { contact, socialUrls, nav } from '../config/site'

const logoImage = import.meta.env.LOGO_IMG || '/ctb-logo-complete.webp'

const socialLinks = [
	{ href: socialUrls.instagram, Icon: IconInstagram, label: 'Instagram' },
	{ href: socialUrls.linkedin, Icon: IconLinkedin, label: 'LinkedIn' },
	{ href: socialUrls.facebook, Icon: IconFacebook, label: 'Facebook' },
].filter(s => s.href !== '#')

const menuBars = Array.from({ length: 3 })
---

<div class="fixed inset-x-0 top-0 z-50 mx-auto max-w-7xl px-4 sm:px-6 lg:px-12" id="main-nav-wrapper">
	<div class="w-full bg-brand-dark/70 backdrop-blur-lg px-4 py-2 text-white flex flex-row items-center justify-between gap-4">
		<div class="flex items-center gap-3">
			{socialLinks.map(({ href, Icon, label }) => (
				<a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="text-white/70 hover:text-white transition">
					<Icon class="w-6 h-6" />
				</a>
			))}
		</div>
		<div class="flex items-center gap-4">
			<a href={`mailto:${contact.email}`} class="flex items-center gap-1.5 text-xs text-white/70 hover:text-white transition">
				<IconEnvelope class="w-6 h-6 shrink-0" />
				<span class="max-md:hidden">{contact.email}</span>
			</a>
			<a href={`tel:${contact.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-1.5 text-xs text-white/70 hover:text-white transition">
				<IconPhone class="w-6 h-6 shrink-0" />
				<span class="max-md:hidden">{contact.phone}</span>
			</a>
		</div>
	</div>
	<header class="w-full bg-brand-light/70 backdrop-blur-lg p-4 lg:py-4 rounded-b-3xl flex flex-col md:flex-row justify-between md:items-center border border-brand-primary/5 shadow-xl shadow-black/5 relative overflow-hidden transition-all">
		<div class="flex justify-between items-center w-full md:w-auto relative z-20">
			<a href="/" class="flex items-center">
				<img src={logoImage} alt="Grupo CTB" class="h-10 lg:h-12 w-auto" />
				<div class="flex flex-col ml-2">
					<span class="font-bold text-green-800">
						Grupo CTB
					</span>
					<span class="text-xs font-bold text-gray-500">
						Construtora e Terraplenagem
					</span>
				</div>
			</a>
			<button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center gap-1.5 p-2 w-10 h-10 cursor-pointer" aria-label="Menu" aria-expanded="false">
				{menuBars.map(() => (
					<span class="w-6 h-0.5 bg-brand-primary rounded-full transition-all duration-300 origin-center"></span>
				))}
			</button>
		</div>
		
		<div id="mobile-menu" class="hidden md:flex flex-col md:flex-row items-center justify-center gap-6 md:gap-8 mt-6 md:mt-0 w-full md:w-auto pb-4 md:pb-0 relative z-10 transition-all opacity-0 md:opacity-100 transform -translate-y-4 md:translate-y-0">
			<nav class="flex flex-col md:flex-row gap-6 md:gap-8 items-center text-center w-full md:w-auto">
				{nav.map(item => (
					<a href={item.href} class="text-brand-primary font-bold md:font-medium hover:text-green-700 transition text-xl md:text-base w-full py-2 md:py-0 border-b border-black/5 md:border-none">{item.label}</a>
				))}
			</nav>
			<a 
				href={whatsappUrl} 
				target="_blank" 
				rel="noopener noreferrer"
				class="mt-4 md:mt-0 px-8 py-4 md:px-6 md:py-2.5 bg-brand-accent text-brand-secondary font-bold text-xl md:text-base rounded-xl hover:bg-brand-primary hover:text-white transition shadow-sm hover:shadow-md w-full md:w-auto text-center"
			>
				Orçamento
			</a>
		</div>
	</header>
</div>

<script>
	const btn = document.getElementById('mobile-menu-btn')
	const menu = document.getElementById('mobile-menu')
	
	if (btn && menu) {
		btn.addEventListener('click', () => {
			const isExpanded = btn.getAttribute('aria-expanded') === 'true'
			btn.setAttribute('aria-expanded', (!isExpanded).toString())
			
			if (!isExpanded) {
				menu.classList.remove('hidden')
				menu.classList.add('flex')
				setTimeout(() => {
					menu.classList.remove('opacity-0', '-translate-y-4')
					menu.classList.add('opacity-100', 'translate-y-0')
				}, 10)
				
				btn.children[0].classList.add('translate-y-2', 'rotate-45')
				btn.children[1].classList.add('opacity-0')
				btn.children[2].classList.add('-translate-y-2', '-rotate-45')
			} else {
				menu.classList.remove('opacity-100', 'translate-y-0')
				menu.classList.add('opacity-0', '-translate-y-4')
				setTimeout(() => {
					menu.classList.add('hidden')
					menu.classList.remove('flex')
				}, 300)
				
				btn.children[0].classList.remove('translate-y-2', 'rotate-45')
				btn.children[1].classList.remove('opacity-0')
				btn.children[2].classList.remove('-translate-y-2', '-rotate-45')
			}
		})
		
		const links = menu.querySelectorAll('a')
		links.forEach(link => {
			link.addEventListener('click', () => {
				if (window.innerWidth < 768 && btn.getAttribute('aria-expanded') === 'true') {
					btn.click()
				}
			})
		})
	}
</script>
