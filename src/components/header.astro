---
const whatsappNumber = import.meta.env.WHATSAPP_NUMBER || '1238842502'
const whatsappUrl = `https://wa.me/55${whatsappNumber}?text=Olá!%20Gostaria%20de%20solicitar%20um%20orçamento.`

const navItems = [
  { label: 'Sobre', href: '#sobre' },
  { label: 'Serviços', href: '#servicos' },
  { label: 'Obras', href: '#obras' },
  { label: 'Contato', href: '#contato' }
]

const menuBars = Array.from({ length: 3 })
---

<div class="fixed inset-x-0 top-0 z-50 mx-auto max-w-7xl px-4 sm:px-6 lg:px-12 pt-4 transition-all duration-300" id="header-container">
  <header class="w-full bg-brand-light/95 backdrop-blur-lg p-4 lg:py-4 lg:px-8 rounded-3xl flex flex-col md:flex-row justify-between md:items-center border border-brand-primary/5 shadow-xl shadow-black/5 relative overflow-hidden transition-all">
    
    <div class="flex justify-between items-center w-full md:w-auto relative z-20">
      <a href="/" class="flex items-center">
        <img src="/ctb-logo-complete.png" alt="CTB Brasil" class="h-10 lg:h-12 w-auto" />
      </a>
      <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center gap-1.5 p-2 w-10 h-10 cursor-pointer" aria-label="Menu" aria-expanded="false">
        {menuBars.map(() => (
          <span class="w-6 h-0.5 bg-brand-primary rounded-full transition-all duration-300 origin-center"></span>
        ))}
      </button>
    </div>
    
    <div id="mobile-menu" class="hidden md:flex flex-col md:flex-row items-center justify-center gap-6 md:gap-8 mt-6 md:mt-0 w-full md:w-auto pb-4 md:pb-0 relative z-10 transition-all opacity-0 md:opacity-100 transform -translate-y-4 md:translate-y-0">
      <nav class="flex flex-col md:flex-row gap-6 md:gap-8 items-center text-center w-full md:w-auto">
        {navItems.map(item => (
          <a href={item.href} class="text-brand-primary font-bold md:font-medium hover:text-brand-accent transition text-xl md:text-base w-full py-2 md:py-0 border-b border-black/5 md:border-none">{item.label}</a>
        ))}
      </nav>
      <a 
        href={whatsappUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="mt-4 md:mt-0 px-8 py-4 md:px-6 md:py-2.5 bg-brand-accent text-brand-secondary font-bold text-xl md:text-base rounded-xl hover:bg-brand-primary hover:text-white transition shadow-sm hover:shadow-md w-full md:w-auto text-center"
      >
        Orçamento
      </a>
    </div>
  </header>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const container = document.getElementById('header-container')
  
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true'
      btn.setAttribute('aria-expanded', (!isExpanded).toString())
      
      if (!isExpanded) {
        // Open
        menu.classList.remove('hidden')
        menu.classList.add('flex')
        // Use a tiny timeout to allow display:flex to apply before kicking CSS transition opacity
        setTimeout(() => {
          menu.classList.remove('opacity-0', '-translate-y-4')
          menu.classList.add('opacity-100', 'translate-y-0')
        }, 10)
        
        btn.children[0].classList.add('translate-y-2', 'rotate-45')
        btn.children[1].classList.add('opacity-0')
        btn.children[2].classList.add('-translate-y-2', '-rotate-45')
      } else {
        // Close
        menu.classList.remove('opacity-100', 'translate-y-0')
        menu.classList.add('opacity-0', '-translate-y-4')
        // Wait for opacity transition then hide
        setTimeout(() => {
          menu.classList.add('hidden')
          menu.classList.remove('flex')
        }, 300)
        
        btn.children[0].classList.remove('translate-y-2', 'rotate-45')
        btn.children[1].classList.remove('opacity-0')
        btn.children[2].classList.remove('-translate-y-2', '-rotate-45')
      }
    })
    
    // Close on anchor click
    const links = menu.querySelectorAll('a')
    links.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 768 && btn.getAttribute('aria-expanded') === 'true') {
          btn.click()
        }
      })
    })
  }

  // Compact header on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      container?.classList.add('pt-2')
      container?.classList.remove('pt-4')
    } else {
      container?.classList.add('pt-4')
      container?.classList.remove('pt-2')
    }
  })
</script>
