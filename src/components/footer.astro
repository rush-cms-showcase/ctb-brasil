---
import IconInstagram from '~icons/ph/instagram-logo-bold'
import IconLinkedin from '~icons/ph/linkedin-logo-bold'
import IconFacebook from '~icons/ph/facebook-logo-bold'

const currentYear = new Date().getFullYear()

const email = import.meta.env.EMAIL || 'ctbbrasil@ctbbrasil.com.br'
const phone = import.meta.env.PHONE_NUMBER || '(12) 3884-2502'
const instagramUrl = import.meta.env.INSTAGRAM_URL || '#'
const facebookUrl = import.meta.env.FACEBOOK_URL || '#'
const linkedinUrl = import.meta.env.LINKEDIN_URL || '#'
const mapsUrl = import.meta.env.GOOGLE_MAPS_URL || '#'

const socialLinks = [
	{ href: instagramUrl, Icon: IconInstagram, label: 'Instagram' },
	{ href: linkedinUrl, Icon: IconLinkedin, label: 'LinkedIn' },
	{ href: facebookUrl, Icon: IconFacebook, label: 'Facebook' }
]

const quickLinks = [
	{ label: 'Sobre a CTB', href: '#sobre' },
	{ label: 'Serviços', href: '#servicos' },
	{ label: 'Nossas Obras', href: '#obras' },
	{ label: 'Fale Conosco', href: '#contato' },
	{ label: 'Política de Privacidade', href: '#' },
	{ label: 'Termos de Uso', href: '#' },
]

const contactLinks = [
	{ label: phone, href: `tel:${phone.replace(/[^0-9]/g, '')}` },
	{ label: email, href: `mailto:${email}` },
	{ label: 'Vale do Paraíba, SP', href: mapsUrl, isExternal: true }
]
---

<footer class="bg-brand-primary text-white pt-20 pb-8 mt-20 rounded-t-3xl">
	<div class="section-container">
		<div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">
			
			<div class="md:col-span-12 lg:col-span-5">
				<a href="/" class="inline-block mb-6">
					<img src="/ctb-logo-complete.png" alt="CTB Brasil" class="h-22 w-auto" />
				</a>
				<p class="text-white/60 max-w-sm mb-8 leading-relaxed font-light">
					Construindo um futuro sustentável com engenharia de ponta, maquinário pesado e excelência no Vale do Paraíba desde 1997.
				</p>
				<div class="flex gap-4">
					{socialLinks.map(social => (
						<a href={social.href} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-brand-accent hover:text-brand-secondary transition text-white" aria-label={social.label}>
							<social.Icon class="w-5 h-5" />
						</a>
					))}
				</div>
			</div>

			<div class="md:col-span-6 lg:col-span-3 lg:col-start-7">
				<h4 class="text-xl font-bold font-display mb-6">Links Rápidos</h4>
				<ul class="flex flex-col gap-4 text-white/60 font-medium tracking-wide">
					{quickLinks.map(link => (
						<li><a href={link.href} class="hover:text-brand-accent transition">{link.label}</a></li>
					))}
				</ul>
			</div>

			<div class="md:col-span-6 lg:col-span-3">
				<h4 class="text-xl font-bold font-display mb-6">Contato</h4>
				<ul class="flex flex-col gap-4 text-white/60 font-medium tracking-wide">
					{contactLinks.map(link => (
						<li>
							<a href={link.href} target={link.isExternal ? "_blank" : "_self"} rel={link.isExternal ? "noopener noreferrer" : ""} class="hover:text-brand-accent transition">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>

		</div>

		<div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-white/40 font-medium tracking-wide">
			<p>&copy; {currentYear} CTB Brasil. Todos os direitos reservados.</p>
		</div>
	</div>
</footer>
