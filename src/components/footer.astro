---
import IconInstagram from '~icons/ph/instagram-logo-bold'
import IconLinkedin from '~icons/ph/linkedin-logo-bold'
import IconFacebook from '~icons/ph/facebook-logo-bold'
import { contact, socialUrls, nav } from '../config/site'

const currentYear = new Date().getFullYear()

const socialLinks = [
	{ href: socialUrls.instagram, Icon: IconInstagram, label: 'Instagram' },
	{ href: socialUrls.linkedin, Icon: IconLinkedin, label: 'LinkedIn' },
	{ href: socialUrls.facebook, Icon: IconFacebook, label: 'Facebook' },
].filter(s => s.href !== '#')

const privacyUrl = import.meta.env.PRIVACY_URL
const termsUrl = import.meta.env.TERMS_URL

const quickLinks = [
	...nav.map(item => ({ label: item.label, href: item.href })),
	...(privacyUrl ? [{ label: 'Política de Privacidade', href: privacyUrl }] : []),
	...(termsUrl ? [{ label: 'Termos de Uso', href: termsUrl }] : []),
]

const contactLinks = [
	{ label: contact.phone, href: `tel:${contact.phone.replace(/[^0-9]/g, '')}` },
	{ label: contact.email, href: `mailto:${contact.email}` },
	{ label: 'Vale do Paraíba, SP', href: contact.mapsUrl, isExternal: true },
]
---

<footer class="w-full lg:px-8">
	<div class="bg-brand-dark text-white pt-20 pb-8 mt-20 rounded-t-3xl">
		<div class="section-container">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">
				
				<div class="md:col-span-12 lg:col-span-5">
					<a href="/" class="inline-block mb-6">
						<img src="/ctb-logo-complete.png" alt="Grupo CTB" class="h-22 w-auto" />
					</a>
					<p class="text-white/60 max-w-sm mb-8 leading-relaxed font-light">
						Construindo um futuro sustentável com engenharia de ponta, maquinário pesado e excelência no Vale do Paraíba desde 1997.
					</p>
					<div class="flex gap-4">
						{socialLinks.map(social => (
							<a href={social.href} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-brand-accent hover:text-brand-secondary transition text-white" aria-label={social.label}>
								<social.Icon class="w-5 h-5" />
							</a>
						))}
					</div>
				</div>

				<div class="md:col-span-6 lg:col-span-3 lg:col-start-7">
					<h4 class="text-xl font-bold font-display mb-6">Links Rápidos</h4>
					<ul class="flex flex-col gap-4 text-white/60 font-medium tracking-wide">
						{quickLinks.map(link => (
							<li><a href={link.href} class="hover:text-brand-accent transition">{link.label}</a></li>
						))}
					</ul>
				</div>

				<div class="md:col-span-6 lg:col-span-3">
					<h4 class="text-xl font-bold font-display mb-6">Contato</h4>
					<ul class="flex flex-col gap-4 text-white/60 font-medium tracking-wide">
						{contactLinks.map(link => (
							<li>
								<a href={link.href} target={link.isExternal ? "_blank" : "_self"} rel={link.isExternal ? "noopener noreferrer" : ""} class="hover:text-brand-accent transition">
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>

			</div>

			<div class="border-t border-white/10 pt-8 flex flex-row lg:flex-row justify-between items-center gap-4 text-sm text-white/40 font-medium tracking-wide">
				<p>GRUPO CTB &copy; {currentYear} - Todos os direitos reservados.</p>
				<p class="flex items-center justify-end flex-row gap-2 text-xs sm:text-sm text-gray-500">
					<span>Feito por</span>
					<a href="https://rafhael.pro?utm_source=ctb-brasil&utm_medium=footer&utm_campaign=created-websites" target="_blank" rel="noopener noreferrer">
						<img src="/rafhael.svg" alt="Rafhael Marsigli" class="w-8 h-8 rounded-md shadow-md" />
					</a>
				</p>
			</div>
			
		</div>
	</div>
</footer>
