---
import SectionHeader from './section-header.astro'

const clients = [
	{ name: 'Alphamare Construtora', img: 'alphamare-construtora.webp' },
	{ name: 'Augusto Veloso', img: 'augusto-veloso.webp' },
	{ name: 'CTL Engenharia', img: 'ctl-engenharia.webp' },
	{ name: 'Engtec Infra', img: 'engtec-infra.webp' },
	{ name: 'G2O Engenharia', img: 'g2o-engenharia.webp' },
	{ name: 'LW Construtora e Incorporadora', img: 'lw-construtora-e-incorporadora.webp' },
	{ name: 'Melhor Forma', img: 'melhor-forma.webp' },
	{ name: 'Prefeitura de Caraguatatuba', img: 'prefeitura-de-caraguatatuba.webp' },
	{ name: 'Prefeitura de Ubatuba', img: 'prefeitura-de-ubatuba.webp' },
	{ name: 'Sabesp', img: 'sabesp.webp' },
	{ name: 'Ubatuba Iate Clube', img: 'ubatuba-iate-clube.webp' },
]
---

<section class="py-24 bg-white">
	<div class="section-container">
		<SectionHeader title="Quem Confia na CTB" className="mb-4 lg:mb-8" />

		<div class="grid grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-4 md:overflow-visible">
			{clients.map(client => (
				<div class="w-hull rounded-2xl overflow-hidden border-2 border-brand-primary/10">
					<img
						src={`/images/companies/${client.img}`}
						alt={client.name}
						class="w-full"
					/>
				</div>
			))}
		</div>
	</div>
</section>
