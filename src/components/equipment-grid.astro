---
import SectionHeader from './section-header.astro'
import IconTruck from '~icons/ph/truck-bold'
import IconMagnifyingGlass from '~icons/ph/magnifying-glass-bold'
import IconCaretDown from '~icons/ph/caret-down-bold'
import equipamentos from '../data/equipamentos.json'

const whatsappNumber = import.meta.env.WHATSAPP_NUMBER || '1238842502'

const categories = [
	{ id: 'todos', label: 'Todos' },
	{ id: 'escavadeiras', label: 'Escavadeiras' },
	{ id: 'caminhoes', label: 'Caminhões' },
	{ id: 'maquinas-pesadas', label: 'Máquinas Pesadas' },
	{ id: 'compactadores', label: 'Compactadores' },
	{ id: 'carregadeiras', label: 'Carregadeiras' },
	{ id: 'plataformas', label: 'Plataformas' },
	{ id: 'outros', label: 'Outros' },
	{ id: 'implementos', label: 'Implementos' },
]
---

<section id="equipamentos" class="py-24">
	<div class="section-container">
		<SectionHeader
			title="Equipamentos para Locação"
			description="Frota própria, revisada e certificada. Pronta para atender sua obra com agilidade."
			className="mb-4 lg:mb-8"
		/>

		<div class="flex flex-col gap-4 mb-10">
			<div class="relative w-full">
				<IconMagnifyingGlass class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-brand-primary/40 pointer-events-none" />
				<input
					type="text"
					id="equipment-search"
					placeholder="Buscar equipamento..."
					class="w-full pl-12 pr-4 py-3 rounded-xl border-2 border-brand-primary/10 bg-white text-brand-primary font-medium placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-primary/40 transition-colors"
				/>
			</div>
			<div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide sm:flex-wrap sm:overflow-visible sm:pb-0" id="equipment-filters">
				{categories.map(cat => (
					<button
						type="button"
						data-filter={cat.id}
						class:list={[
							"px-4 py-2 rounded-full text-sm font-bold transition-all duration-300 cursor-pointer border-2 whitespace-nowrap shrink-0 sm:shrink",
							cat.id === 'todos'
								? 'bg-brand-primary text-white border-brand-primary'
								: 'bg-transparent text-brand-primary/70 border-brand-primary/15 hover:border-brand-primary/40'
						]}
					>
						{cat.label}
					</button>
				))}
			</div>
		</div>

		<div class="relative" id="equipment-wrapper">
			<div
				class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 overflow-hidden transition-[max-height] duration-500 ease-in-out"
				id="equipment-grid"
			>
				{equipamentos.map(equip => {
					const whatsappText = encodeURIComponent(`Olá! Gostaria de alugar o equipamento ${equip.name}`)
					const whatsappLink = `https://wa.me/55${whatsappNumber}?text=${whatsappText}`
					return (
						<div
							class="equipment-card rounded-2xl border-2 border-brand-primary/8 bg-white overflow-hidden flex flex-col h-full"
							data-category={equip.category}
							data-name={equip.name.toLowerCase()}
						>
							<div class="aspect-4/3 bg-brand-primary/5 flex items-center justify-center">
								{equip.image ? (
									<img
										src={equip.image}
										alt={equip.name}
										class="w-full h-full object-cover"
										loading="lazy"
										decoding="async"
										width={400}
										height={300}
									/>
								) : (
									<div class="flex flex-col items-center text-brand-primary/15">
										<IconTruck class="w-12 h-12" />
									</div>
								)}
							</div>
							<div class="p-4 flex flex-col gap-2 grow">
								<div>
									<h3 class="font-bold text-sm text-brand-primary leading-tight">{equip.name}</h3>
									{(equip.weight || equip.description) && (
										<p class="text-xs text-brand-primary/50 font-medium mt-0.5">
											{equip.weight || equip.description}
										</p>
									)}
								</div>
								<a
									href={whatsappLink}
									target="_blank"
									rel="noopener noreferrer"
									class="uppercase flex items-center justify-center gap-1.5 w-full py-2 mt-auto bg-brand-primary/10 text-brand-primary text-xs font-bold rounded-lg hover:bg-brand-accent hover:text-brand-dark transition-all duration-300"
								>
									Solicitar
								</a>
							</div>
						</div>
					)
				})}
			</div>

			<div
				id="equipment-fade"
				class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-brand-light to-transparent pointer-events-none transition-opacity duration-300"
			></div>
		</div>

		<div class="flex justify-center mt-8" id="equipment-expand-wrapper">
			<button
				type="button"
				id="equipment-expand"
				class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border-2 border-brand-primary/15 text-brand-primary font-bold hover:bg-brand-primary hover:text-white transition-all duration-300 cursor-pointer"
			>
				<span id="expand-text">Mostrar todos</span>
				<IconCaretDown class="w-5 h-5 transition-transform duration-300" id="expand-icon" />
			</button>
		</div>

		<p id="equipment-empty" class="hidden text-center text-brand-primary/40 font-medium py-16 text-lg">
			Nenhum equipamento encontrado.
		</p>
	</div>
</section>

<script>
	const filters = document.getElementById('equipment-filters')
	const grid = document.getElementById('equipment-grid') as HTMLElement
	const cards = document.querySelectorAll('.equipment-card')
	const searchInput = document.getElementById('equipment-search') as HTMLInputElement
	const expandBtn = document.getElementById('equipment-expand') as HTMLElement
	const expandText = document.getElementById('expand-text') as HTMLElement
	const expandIcon = document.getElementById('expand-icon') as HTMLElement
	const expandWrapper = document.getElementById('equipment-expand-wrapper') as HTMLElement
	const fadeOverlay = document.getElementById('equipment-fade') as HTMLElement
	const emptyMsg = document.getElementById('equipment-empty') as HTMLElement

	let expanded = false
	let activeFilter = 'todos'
	let searchQuery = ''

	function getCollapsedHeight() {
		const firstCard = grid.querySelector('.equipment-card:not([style*="display: none"])') as HTMLElement
		if (!firstCard) return 400
		const cardHeight = firstCard.offsetHeight
		const gap = 16
		return Math.floor(cardHeight * 1.6 + gap)
	}

	function applyFilters() {
		let visibleCount = 0

		cards.forEach(card => {
			const el = card as HTMLElement
			const matchesCategory = activeFilter === 'todos' || el.dataset.category === activeFilter
			const matchesSearch = !searchQuery || (el.dataset.name || '').includes(searchQuery)

			if (matchesCategory && matchesSearch) {
				el.style.display = ''
				visibleCount++
			} else {
				el.style.display = 'none'
			}
		})

		emptyMsg.classList.toggle('hidden', visibleCount > 0)
		grid.classList.toggle('hidden', visibleCount === 0)

		updateCollapse(visibleCount)
	}

	function updateCollapse(visibleCount: number) {
		requestAnimationFrame(() => {
			const collapsedH = getCollapsedHeight()
			const fullH = grid.scrollHeight

			const needsCollapse = fullH > collapsedH + 50

			if (!needsCollapse || expanded || searchQuery) {
				grid.style.maxHeight = ''
				fadeOverlay.style.opacity = '0'
				expandWrapper.style.display = searchQuery && !expanded ? 'none' : (needsCollapse ? '' : 'none')
			} else {
				grid.style.maxHeight = collapsedH + 'px'
				fadeOverlay.style.opacity = '1'
				expandWrapper.style.display = ''
			}
		})
	}

	if (filters) {
		filters.addEventListener('click', (e) => {
			const btn = (e.target as HTMLElement).closest('[data-filter]') as HTMLElement
			if (!btn) return

			activeFilter = btn.dataset.filter || 'todos'
			expanded = false
			expandText.textContent = 'Mostrar todos'
			expandIcon.style.transform = ''

			filters.querySelectorAll('[data-filter]').forEach(b => {
				b.classList.remove('bg-brand-primary', 'text-white', 'border-brand-primary')
				b.classList.add('bg-transparent', 'text-brand-primary/70', 'border-brand-primary/15')
			})
			btn.classList.remove('bg-transparent', 'text-brand-primary/70', 'border-brand-primary/15')
			btn.classList.add('bg-brand-primary', 'text-white', 'border-brand-primary')

			applyFilters()
		})
	}

	if (searchInput) {
		searchInput.addEventListener('input', () => {
			searchQuery = searchInput.value.toLowerCase().trim()
			expanded = false
			expandText.textContent = 'Mostrar todos'
			expandIcon.style.transform = ''
			applyFilters()
		})
	}

	if (expandBtn) {
		expandBtn.addEventListener('click', () => {
			expanded = !expanded
			if (expanded) {
				grid.style.maxHeight = grid.scrollHeight + 'px'
				fadeOverlay.style.opacity = '0'
				expandText.textContent = 'Mostrar menos'
				expandIcon.style.transform = 'rotate(180deg)'
			} else {
				grid.style.maxHeight = getCollapsedHeight() + 'px'
				fadeOverlay.style.opacity = '1'
				expandText.textContent = 'Mostrar todos'
				expandIcon.style.transform = ''
			}
		})
	}

	applyFilters()
</script>
