---
import IconPath from '~icons/ph/path-bold'
import IconBuildings from '~icons/ph/buildings-bold'
import IconTractor from '~icons/ph/tractor-bold'

const secondaryStats = [
	{
		theme: 'light',
		Icon: IconBuildings,
		number: '+150',
		highlight: 'Obras',
		highlightClass: 'text-xl uppercase tracking-wider',
		description: 'Projetos sob medida gerando economia e segurança no investimento.'
	},
	{
		theme: 'dark',
		Icon: IconTractor,
		number: '100',
		highlight: '%',
		highlightClass: 'text-4xl',
		description: 'Maquinário vistoriado e atualizado para diversos tipos de terrenos.'
	}
]
---

<section class="w-full relative z-20 -mt-16 sm:-mt-24 mx-auto max-w-7xl px-6 lg:px-12">
	<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
		
		<div class="lg:col-span-8 bg-brand-primary rounded-3xl p-10 sm:p-14 shadow-2xl relative overflow-hidden flex flex-col justify-center">
			<div class="absolute -right-20 -top-20 w-96 h-96 bg-brand-accent/20 rounded-full blur-[80px] animate-pulse"></div>
			
			<div class="relative z-10">
				<div class="w-16 h-16 rounded-2xl bg-brand-accent text-brand-secondary flex items-center justify-center mb-8 shadow-lg shadow-brand-accent/20">
					<IconPath class="w-8 h-8" />
				</div>
				<h3 class="text-6xl sm:text-7xl lg:text-8xl font-display font-black text-white mb-4 tracking-tight drop-shadow-sm">
					+28<span class="text-brand-accent text-4xl sm:text-5xl lg:text-6xl ml-2 font-bold">Anos</span>
				</h3>
				<p class="text-white/70 text-xl sm:text-2xl max-w-lg leading-relaxed">
					De pioneirismo absoluto no setor de Construção Civil e Terraplenagem.
				</p>
			</div>
		</div>

		<div class="lg:col-span-4 flex flex-col gap-6">
			{secondaryStats.map(stat => (
				<div class={`flex-1 rounded-3xl p-8 shadow-xl flex flex-col justify-center relative overflow-hidden ${stat.theme === 'light' ? 'bg-white border border-black/5' : 'bg-brand-secondary'}`}>
					{stat.theme === 'dark' && (
						<div class="absolute -left-10 -bottom-10 w-40 h-40 bg-brand-accent/10 rounded-full blur-2xl"></div>
					)}
					<div class="relative z-10 flex flex-col sm:flex-row lg:flex-col xl:flex-row xl:items-center gap-4 mb-4">
						<div class={`w-14 h-14 shrink-0 rounded-2xl flex items-center justify-center ${stat.theme === 'light' ? 'bg-brand-primary/5 text-brand-primary' : 'bg-white/10 text-brand-accent'}`}>
							 <stat.Icon class="w-7 h-7" />
						</div>
						<h3 class={`text-5xl font-display font-bold ${stat.theme === 'light' ? 'text-brand-primary' : 'text-white'}`}>
							{stat.number}<span class={`text-brand-accent ml-1 ${stat.highlightClass}`}>{stat.highlight}</span>
						</h3>
					</div>
					<p class={`text-base font-medium leading-relaxed ${stat.theme === 'light' ? 'text-brand-primary/60' : 'text-white/60'}`}>
						{stat.description}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
