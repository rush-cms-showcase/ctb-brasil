---
import BaseLayout from '../layouts/base-layout.astro'
import BusinessCards from '../components/business-cards.astro'
import { contact } from '../config/site'

const schemaData = {
	"@context": "https://schema.org",
	"@type": "ContactPage",
	"name": "Contato - Grupo CTB",
	"description": "Entre em contato com o Grupo CTB para solicitar orçamentos, alugar equipamentos ou tirar dúvidas.",
	"mainEntity": {
		"@type": "Organization",
		"name": "Grupo CTB",
		"telephone": contact.phone,
		"email": contact.email,
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Rua Três, 95 - Tabatinga",
			"addressLocality": "Caraguatatuba",
			"addressRegion": "SP",
			"postalCode": "11679-209",
			"addressCountry": "BR"
		}
	}
}
---

<BaseLayout title="Contato | Grupo CTB" description="Entre em contato com o Grupo CTB. Solicite orçamentos para terraplenagem, construção civil, locação de equipamentos e mais.">
	<Fragment slot="head">
		<link rel="canonical" href="https://www.ctbbrasil.com.br/contato" />
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
	</Fragment>

	<main class="pt-40 pb-0">
		<BusinessCards />

		<div class="section-container pb-24">
			<div class="w-full h-96 lg:h-[500px] rounded-3xl overflow-hidden border-2 border-brand-primary/10 shadow-xl relative z-10">
				<iframe
					src={contact.mapsEmbedUrl}
					width="100%"
					height="100%"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					class="absolute inset-0"
				></iframe>
			</div>
		</div>
	</main>
</BaseLayout>
