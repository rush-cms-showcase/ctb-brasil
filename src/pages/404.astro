---
import BaseLayout from '../layouts/base-layout.astro'
import IconArrowLeft from '~icons/ph/arrow-left-bold'
import IconWarning from '~icons/ph/warning-circle-bold'
---

<BaseLayout title="Página não encontrada | CTB Brasil" description="A página que você procura não existe.">
  <main class="flex items-center justify-center relative overflow-hidden px-6 py-32 lg:py-48">
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-brand-accent rounded-full mix-blend-screen blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-secondary rounded-full mix-blend-screen blur-[120px] animate-pulse" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="relative z-10 max-w-2xl text-center">
      <div class="flex justify-center mb-8">
        <div class="w-24 h-24 bg-brand-accent/20 rounded-full flex items-center justify-center backdrop-blur-sm border border-brand-accent/30 shadow-lg shadow-brand-accent/10">
          <IconWarning class="w-12 h-12 text-brand-accent" />
        </div>
      </div>
      
      <h1 class="text-8xl md:text-[12rem] leading-none font-display font-black text-brand-primary tracking-tighter mb-2 drop-shadow-xl">
        4<span class="text-brand-accent">0</span>4
      </h1>
      
      <h2 class="text-3xl md:text-5xl font-display font-bold text-brand-primary mb-6 tracking-tight">
        Caminho Interrompido
      </h2>
      
      <p class="text-lg md:text-xl text-brand-primary/70 mb-12 max-w-lg mx-auto text-balance font-medium leading-relaxed">
        A página que você está procurando foi movida, removida ou talvez ainda esteja em fase de fundação.
      </p>
      
      <div class="flex justify-center">
        <a 
          href="/" 
          class="inline-flex items-center gap-3 px-8 py-4 bg-brand-accent text-brand-secondary font-bold text-lg rounded-xl hover:bg-white hover:text-brand-primary hover:-translate-y-1 hover:shadow-2xl hover:shadow-brand-accent/30 transition-all duration-300 w-full sm:w-auto justify-center"
        >
          <IconArrowLeft class="w-6 h-6" />
          Voltar para a Home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
