---
import BaseLayout from '../../layouts/base-layout.astro'
import { whatsappUrl } from '../../utils/whatsapp'
import { contact } from '../../config/site'
import IconWhatsappLogo from '~icons/ph/whatsapp-logo'

import { services } from '../../data/services'

export async function getStaticPaths() {
	const files = import.meta.glob<{ compiledContent: () => string }>('/src/content/servicos/*.md', { eager: true })
	return services.map(service => {
		const mdKey = `/src/content/servicos/${service.id}.md`
		const mod = files[mdKey]
		return {
			params: { slug: service.id },
			props: { service, content: mod ? mod.compiledContent() : '' }
		}
	})
}

let { service, content } = Astro.props as { service?: import('../../data/services').Service, content?: string }
const slug = Astro.params.slug

if (!service) {
	service = services.find(s => s.id === slug)
	if (!service) return Astro.redirect('/404')
	const files = import.meta.glob<{ compiledContent: () => string }>('/src/content/servicos/*.md', { eager: true })
	const mod = files[`/src/content/servicos/${service.id}.md`]
	content = mod ? mod.compiledContent() : ''
}

const { title, description, img: image } = service!
const canonicalUrl = `https://www.ctbbrasil.com.br/servicos/${slug}`

const schemaData = {
	"@context": "https://schema.org",
	"@type": "Service",
	"name": title,
	"description": description,
	"provider": {
		"@type": "Organization",
		"name": "Grupo CTB",
		"url": "https://www.ctbbrasil.com.br",
		"telephone": contact.phone,
		"email": contact.email,
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Rua Três, 95 - Tabatinga",
			"addressLocality": "Caraguatatuba",
			"addressRegion": "SP",
			"postalCode": "11679-209",
			"addressCountry": "BR"
		}
	},
	"areaServed": {
		"@type": "GeoCircle",
		"geoMidpoint": { "@type": "GeoCoordinates", "latitude": -23.5769, "longitude": -45.2730 },
		"geoRadius": "100000"
	}
}
---

<BaseLayout title={`${title} | Grupo CTB`} description={description}>
	<Fragment slot="head">
		<link rel="canonical" href={canonicalUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
	</Fragment>

	<main>
		<section class="w-full lg:px-8">
			<div class="relative w-full h-[50vh] min-h-80 lg:min-h-96 flex items-end overflow-hidden rounded-b-4xl">
				<div 
					class="absolute -inset-10 bg-fixed bg-center bg-cover bg-no-repeat blur-[6px]" 
					style={`background-image: url('/images/services/${image}')`}
				></div>
				<div class="absolute inset-0 bg-linear-to-t from-brand-dark/90 via-brand-dark/50 to-transparent"></div>
				<div class="section-container relative z-10 pb-12 lg:pb-16 w-full">
					<h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-extrabold text-white max-w-3xl drop-shadow-lg">{title}</h1>
				</div>
			</div>
		</section>

		<section class="py-16 lg:py-24">
			<div class="section-container">
				<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
					<article class="lg:col-span-8 prose prose-lg xl:prose-xl max-w-none" set:html={content} />

					<aside class="lg:col-span-4">
						<div class="sticky top-32 flex flex-col gap-6">
							<div class="bg-brand-primary rounded-2xl p-8 text-white">
								<h3 class="text-2xl font-display font-bold mb-3">Solicite um Orçamento</h3>
								<p class="text-white/70 mb-6 leading-relaxed">Entre em contato com nossa equipe e receba uma proposta personalizada para a sua obra.</p>
								<a
									href={whatsappUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="flex items-center justify-center gap-2 w-full py-3 bg-brand-accent text-brand-primary font-bold rounded-xl hover:bg-green-900 hover:text-brand-accent transition-all duration-300"
								>
									<IconWhatsappLogo class="w-5 h-5" />
									Falar no WhatsApp
								</a>
							</div>

							<div class="border-2 border-brand-primary/10 rounded-2xl p-8">
								<h3 class="text-lg font-display font-bold text-brand-primary mb-4">Contato Direto</h3>
								<div class="flex flex-col gap-3 text-sm">
									<a href={`tel:${contact.phone.replace(/[^0-9]/g, '')}`} class="text-brand-primary/70 hover:text-brand-primary transition font-medium">{contact.phone}</a>
									<a href={`mailto:${contact.email}`} class="text-brand-primary/70 hover:text-brand-primary transition font-medium">{contact.email}</a>
								</div>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<style is:global>
	.prose h1 {
		display: none;
	}
	.prose h2 {
		font-family: var(--font-display);
		color: var(--color-brand-primary);
		font-weight: 700;
		font-size: 1.75rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}
	.prose h3 {
		font-family: var(--font-display);
		color: var(--color-brand-primary);
		font-weight: 600;
		font-size: 1.25rem;
		margin-top: 2rem;
	}
	.prose p {
		color: var(--color-brand-primary);
		opacity: 0.75;
		line-height: 1.9;
	}
	.prose ul {
		color: var(--color-brand-primary);
		opacity: 0.75;
	}
	.prose li {
		margin-bottom: 0.5rem;
		line-height: 1.7;
	}
	.prose strong {
		color: var(--color-brand-primary);
		opacity: 1;
	}
</style>
